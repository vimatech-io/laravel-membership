{
    "name": "vimatech/laravel-membership",
    "description": "Polymorphic memberships for Laravel.",
    "keywords": ["laravel", "membership", "polymorphic", "roles", "teams", "organizations"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Adel Zemzemi",
            "email": "hello@adelzemzemi.dev"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/contracts": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Vimatech\\Membership\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Vimatech\\Membership\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Vimatech\\Membership\\MembershipServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
